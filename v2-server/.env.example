# V2 Database (separate Railway Postgres instance with pgvector)
V2_DATABASE_URL=postgresql://user:pass@host:5432/imc_v2

# Server
V2_PORT=3002

# Auth (can share JWT_SECRET with V1 for single-login, or use separate)
JWT_SECRET=your-secret-here

# AI
ANTHROPIC_API_KEY=your-key
OPENAI_API_KEY=your-key  # for embeddings (text-embedding-3-large)

# External APIs
ARENA_ACCESS_TOKEN=
EUROPEANA_API_KEY=
FREESOUND_API_KEY=
RIJKSMUSEUM_API_KEY=
DISCOGS_TOKEN=
# Internet Archive, MusicBrainz, ccMixter = no key required
